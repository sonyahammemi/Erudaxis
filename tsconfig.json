{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "playwright"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "tests/**/*",
    "pages/**/*",
    "config/**/*",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"]
}